NODE_ENV=development
BACKEND_PORT=8080
FRONTEND_PORT=5173
API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=ims_password
POSTGRES_DB=ims_db
POSTGRES_SSL=false
MONGO_URL=mongodb://mongo:27017
MONGO_DB=ims_raw
REDIS_URL=redis://redis:6379
INGESTION_RATE_LIMIT_WINDOW_MS=1000
INGESTION_RATE_LIMIT_MAX=10000
SIGNAL_QUEUE_MAX_SIZE=50000
SIGNAL_BATCH_SIZE=500
SIGNAL_PROCESS_INTERVAL_MS=250
DEBOUNCE_WINDOW_MS=10000
DB_RETRY_ATTEMPTS=3
DB_RETRY_BASE_DELAY_MS=250
METRICS_LOG_INTERVAL_MS=5000
CORS_ORIGIN=http://localhost:5173
